#!/usr/bin/env bash
set -euo pipefail

fail() {
  printf '%s\n' "$*" >&2
  exit 1
}

command -v npm >/dev/null || fail "pre-push requires npm"

has_updates=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi
  has_updates=1
done

[ "$has_updates" -eq 1 ] || exit 0

npm run verify
