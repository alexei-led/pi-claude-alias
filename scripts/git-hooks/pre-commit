#!/usr/bin/env bash
set -euo pipefail

fail() {
  printf '%s\n' "$*" >&2
  exit 1
}

command -v git >/dev/null || fail "pre-commit requires git"
command -v node >/dev/null || fail "pre-commit requires node"
command -v npm >/dev/null || fail "pre-commit requires npm"

staged_files=()
while IFS= read -r -d '' path; do
  staged_files+=("$path")
done < <(git diff --cached --name-only -z --diff-filter=ACMR)

((${#staged_files[@]})) || exit 0

js_ts_files=()
json_files=()
yaml_files=()

for file in "${staged_files[@]}"; do
  case "$file" in
    *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs)
      js_ts_files+=("$file")
      ;;
    *.json)
      json_files+=("$file")
      ;;
    .github/workflows/*.yml|.github/workflows/*.yaml)
      yaml_files+=("$file")
      ;;
  esac
done

if ((${#json_files[@]})); then
  node -e 'const fs = require("node:fs"); for (const file of process.argv.slice(1)) { JSON.parse(fs.readFileSync(file, "utf8")); }' "${json_files[@]}"
fi

if ((${#yaml_files[@]})); then
  command -v ruby >/dev/null || fail "pre-commit requires ruby to validate workflow YAML"
  ruby -e 'require "yaml"; ARGV.each { |file| YAML.load_file(file) }' "${yaml_files[@]}"
fi

if ((${#js_ts_files[@]})); then
  [ -x ./node_modules/.bin/eslint ] || fail "pre-commit requires npm install before linting"
  ./node_modules/.bin/eslint --cache --cache-strategy content "${js_ts_files[@]}"
fi
